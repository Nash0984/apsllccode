# RESEND_API_KEY: Required for email delivery of contact form inquiries.
# Get your key at https://resend.com
RESEND_API_KEY=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# This is a server-side only secret and must NOT be prefixed with VITE_.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLOUDFLARE PAGES NOTES:
# 1. Set GEMINI_API_KEY in the Cloudflare Pages Dashboard (Settings > Functions > Variables).
# 2. The 'public/_redirects' file handles SPA routing.
# 3. Backend logic is located in the '/functions' directory.
